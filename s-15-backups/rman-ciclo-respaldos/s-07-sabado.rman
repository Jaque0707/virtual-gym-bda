# autenticar a nivel de la cdb como sys

connect target "sys/systemP as sysdba"

BACKUP AS BACKUPSET INCREMENTAL LEVEL 1 DATABASE 
PLUS ARCHIVELOG TAG 'SABADO_DIFF';

# Limpieza final de la semana # Es necesario o no?
# DELETE NOPROMPT OBSOLETE;

exit;