#Descripción: 
# autenticar a nivel de la cdb como sys

connect target "sys/systemP as sysdba"

# Por defecto, el nivel 1 es diferencial (cambios desde el último nivel 1 o 0)
backup as backupset incremental level 1 database plus archivelog tag 'c0_free_dif_bs_n1_03';

exit;

