# autenticar a nivel de la cdb como sys

connect target "sys/systemP as sysdba"

# Respalda solo cambios desde el acumulativo del Martes
backup as backupset incremental level 1 database plus archivelog tag 'c0_free_dif_bs_n1_05';

exit;